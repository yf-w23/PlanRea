// PlanRea - AI日程规划与计划执行应用
// Prisma Schema 定义

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举类型 ====================

enum PlanStatus {
  ACTIVE      // 进行中
  COMPLETED   // 已完成
  ARCHIVED    // 已归档
  CANCELLED   // 已取消
}

enum TaskStatus {
  TODO        // 待办
  IN_PROGRESS // 进行中
  COMPLETED   // 已完成
  BLOCKED     // 被阻塞
  CANCELLED   // 已取消
}

enum TaskPriority {
  LOW      // 低
  MEDIUM   // 中
  HIGH     // 高
  URGENT   // 紧急
}

enum EnergyLevel {
  VERY_LOW  // 很低
  LOW       // 低
  MEDIUM    // 中
  HIGH      // 高
  VERY_HIGH // 很高
}

enum TaskCategory {
  WORK         // 工作
  STUDY        // 学习
  PERSONAL     // 个人
  HEALTH       // 健康
  CREATIVE     // 创作
  ADMIN        // 行政事务
  MEETING      // 会议
  BREAK        // 休息
}

enum CalendarProvider {
  GOOGLE     // Google Calendar
  OUTLOOK    // Microsoft Outlook
  APPLE      // Apple Calendar
  LOCAL      // 本地日历
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ScheduleStatus {
  DRAFT      // 草稿
  CONFIRMED  // 已确认
  EXECUTING  // 执行中
  COMPLETED  // 已完成
}

// ==================== 模型定义 ====================

// 用户模型
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  avatar    String?  // 头像URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系
  preferences        UserPreferences?
  plans              Plan[]
  tasks              Task[]
  calendarConnections CalendarConnection[]
  schedules          Schedule[]
  behaviorPatterns   BehaviorPattern[]
  energyLogs         EnergyLog[]

  @@map("users")
}

// 用户偏好设置
model UserPreferences {
  id                    String    @id @default(uuid())
  userId                String    @unique
  
  // 工作设置
  workStartTime         String    @default("09:00")  // HH:mm 格式
  workEndTime           String    @default("18:00")
  workDays              DayOfWeek[] @default([MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY])
  
  // 时间管理
  defaultTaskDuration   Int       @default(30)  // 默认任务时长(分钟)
  breakDuration         Int       @default(10)  // 休息时长(分钟)
  longBreakDuration     Int       @default(30)  // 长休息时长(分钟)
  pomodoroWorkDuration  Int       @default(25)  // 番茄钟工作时长
  
  // 精力管理
  preferredEnergyLevel  EnergyLevel @default(MEDIUM)
  morningEnergyLevel    EnergyLevel @default(HIGH)
  afternoonEnergyLevel  EnergyLevel @default(MEDIUM)
  eveningEnergyLevel    EnergyLevel @default(LOW)
  
  // 通知设置
  emailNotifications    Boolean   @default(true)
  pushNotifications     Boolean   @default(true)
  reminderBeforeMinutes Int       @default(15)
  
  // 时区与语言
  timezone              String    @default("Asia/Shanghai")
  language              String    @default("zh-CN")
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // 关系
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// 计划模型
model Plan {
  id          String     @id @default(uuid())
  userId      String
  
  title       String
  description String?    @db.Text
  goal        String?    @db.Text  // 计划目标
  deadline    DateTime?  // 截止日期
  status      PlanStatus @default(ACTIVE)
  progress    Float      @default(0)  // 进度百分比 0-100
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // 关系
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([userId])
  @@index([status])
  @@map("plans")
}

// 任务模型
model Task {
  id               String       @id @default(uuid())
  userId           String
  planId           String?
  
  title            String
  description      String?      @db.Text
  
  // 时间估算与追踪
  estimatedMinutes Int          // 预计耗时(分钟)
  actualMinutes    Int?         // 实际耗时(分钟)
  
  // 任务属性
  priority         TaskPriority @default(MEDIUM)
  energyLevel      EnergyLevel  @default(MEDIUM)  // 所需精力水平
  category         TaskCategory @default(WORK)
  status           TaskStatus   @default(TODO)
  
  // 时间安排
  scheduledDate    DateTime?    // 计划执行日期
  scheduledStart   DateTime?    // 计划开始时间
  scheduledEnd     DateTime?    // 计划结束时间
  
  // 位置与上下文
  location         String?      // 地点
  contextTags      String[]     @default([])  // 上下文标签 ["电脑", "手机", "外出"]
  
  // 排序与依赖
  orderIndex       Int          @default(0)  // 同计划内排序
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  completedAt      DateTime?    // 完成时间

  // 关系
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  // 依赖关系
  dependencies     TaskDependency[] @relation("TaskDependencies")
  dependents       TaskDependency[] @relation("TaskDependents")
  
  // 日历事件关联
  calendarEvents   CalendarEvent[]
  
  // 时间块关联
  timeBlocks       TimeBlock[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([scheduledDate])
  @@index([category])
  @@map("tasks")
}

// 任务依赖关系
model TaskDependency {
  id             String @id @default(uuid())
  taskId         String // 依赖此任务的任务（子任务）
  dependsOnId    String // 被依赖的任务（父任务）
  
  dependencyType String @default("BLOCKS") // BLOCKS, RELATES_TO, DUPLICATES
  
  createdAt      DateTime @default(now())

  // 关系
  task           Task   @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn      Task   @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

// 日历连接配置
model CalendarConnection {
  id           String           @id @default(uuid())
  userId       String
  
  provider     CalendarProvider
  providerId   String           // 第三方日历ID
  accountEmail String           // 关联的邮箱
  
  // OAuth 凭证（加密存储）
  accessToken  String           @db.Text
  refreshToken String?          @db.Text
  tokenExpiresAt DateTime?
  
  // 同步设置
  syncEnabled  Boolean          @default(true)
  syncFromDate DateTime?        // 同步起始日期
  syncToDate   DateTime?        // 同步结束日期
  
  // 双向同步选项
  importEvents Boolean          @default(true)  // 导入外部事件
  exportTasks  Boolean          @default(true)  // 导出任务到日历
  
  lastSyncAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // 关系
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       CalendarEvent[]

  @@unique([userId, provider, accountEmail])
  @@index([userId])
  @@map("calendar_connections")
}

// 日历事件（外部日历导入的事件或导出的任务）
model CalendarEvent {
  id                   String   @id @default(uuid())
  calendarConnectionId String
  
  // 事件来源
  externalEventId      String?  // 第三方日历的事件ID
  taskId               String?  // 关联的任务ID（如果是导出的任务）
  
  // 事件详情
  title                String
  description          String?  @db.Text
  location             String?
  
  // 时间
  startTime            DateTime
  endTime              DateTime
  isAllDay             Boolean  @default(false)
  timezone             String   @default("Asia/Shanghai")
  
  // 重复规则（iCal RRULE格式）
  recurrenceRule       String?
  recurrenceException  DateTime[] // 例外日期
  
  // 参与者
  attendees            Json?    // [{ email, name, status }]
  organizer            Json?    // { email, name }
  
  // 状态
  status               String   @default("CONFIRMED") // TENTATIVE, CONFIRMED, CANCELLED
  
  // 同步元数据
  lastSyncedAt         DateTime @default(now())
  etag                 String?  // 用于增量同步
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // 关系
  calendarConnection   CalendarConnection @relation(fields: [calendarConnectionId], references: [id], onDelete: Cascade)
  task                 Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([calendarConnectionId])
  @@index([taskId])
  @@index([startTime])
  @@map("calendar_events")
}

// 日程表（AI生成的每日/每周日程安排）
model Schedule {
  id            String         @id @default(uuid())
  userId        String
  
  title         String         // 日程标题，如 "周一日程 2024-01-15"
  description   String?        @db.Text
  
  // 时间范围
  startDate     DateTime       // 日程开始日期
  endDate       DateTime       // 日程结束日期
  
  // 日程状态
  status        ScheduleStatus @default(DRAFT)
  
  // AI生成参数
  aiModel       String?        // 使用的AI模型
  aiPrompt      String?        @db.Text  // 生成提示词
  aiResponse    String?        @db.Text  // AI原始响应
  
  // 优化统计
  totalTasks    Int            @default(0)
  completedTasks Int           @default(0)
  totalMinutes  Int            @default(0)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  confirmedAt   DateTime?      // 用户确认时间

  // 关系
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeBlocks    TimeBlock[]

  @@index([userId])
  @@index([startDate])
  @@index([status])
  @@map("schedules")
}

// 时间块（日程的具体时间段分配）
model TimeBlock {
  id          String    @id @default(uuid())
  scheduleId  String
  taskId      String?   // 关联的任务
  
  // 时间
  startTime   DateTime
  endTime     DateTime
  
  // 块类型
  blockType   String    @default("TASK") // TASK, BREAK, BUFFER, FIXED
  
  // 状态
  status      String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, SKIPPED
  
  // 实际执行记录
  actualStartTime DateTime?
  actualEndTime   DateTime?
  
  // AI推荐理由
  aiReasoning String?   @db.Text // 为什么安排在这个时间段
  
  // 用户反馈
  userRating  Int?      // 1-5 评分
  userFeedback String?  @db.Text // 用户反馈文本
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关系
  schedule    Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([scheduleId])
  @@index([taskId])
  @@index([startTime])
  @@map("time_blocks")
}

// 用户行为模式（AI学习用户习惯）
model BehaviorPattern {
  id          String   @id @default(uuid())
  userId      String
  
  // 模式类型
  patternType String   // PRODUCTIVITY_PEAK, TASK_COMPLETION_RATE, CATEGORY_PREFERENCE, ENERGY_PATTERN
  
  // 模式数据
  patternKey  String   // 具体标识，如 "MORNING", "WORK", "HIGH_ENERGY"
  patternValue Float   // 数值，如效率评分、完成率等
  
  // 统计依据
  sampleSize  Int      @default(0)  // 样本数量
  confidence  Float    @default(0)  // 置信度 0-1
  
  // 时间范围
  dateFrom    DateTime // 统计开始日期
  dateTo      DateTime // 统计结束日期
  
  // 详细信息（JSON格式）
  metadata    Json?    // 额外统计数据
  
  // AI分析
  aiInsight   String?  @db.Text // AI洞察文本
  
  // 过期与更新
  isActive    Boolean  @default(true)
  expiresAt   DateTime? // 模式过期时间
  lastUpdated DateTime @default(now())
  
  createdAt   DateTime @default(now())

  // 关系
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, patternType, patternKey])
  @@index([userId])
  @@index([patternType])
  @@index([isActive])
  @@map("behavior_patterns")
}

// 精力日志（用户记录的精力状态）
model EnergyLog {
  id          String      @id @default(uuid())
  userId      String
  
  // 记录时间
  loggedAt    DateTime
  
  // 精力状态
  energyLevel EnergyLevel
  fatigueLevel Int?       // 疲劳程度 1-5
  
  // 影响因素
  sleepHours   Float?     // 睡眠时长
  sleepQuality Int?       // 睡眠质量 1-5
  caffeineMg   Int?       // 咖啡因摄入量(mg)
  mealStatus   String?    // 餐前/餐后/空腹
  exerciseDone Boolean    @default(false)
  
  // 环境与心情
  mood         String?    // 心情描述
  stressLevel  Int?       // 压力水平 1-5
  environment  String?    // 环境描述
  
  // 备注
  notes        String?    @db.Text
  
  // 关联的任务（如果在执行任务时记录）
  taskId       String?
  
  createdAt    DateTime   @default(now())

  // 关系
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@index([energyLevel])
  @@map("energy_logs")
}
